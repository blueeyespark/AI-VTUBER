diff --git a/Project Blue App/desktop_pet/upgrade-sync.cjs b/Project Blue App/desktop_pet/upgrade-sync.cjs
new file mode 100644
index 0000000..cb0fb54
--- /dev/null
+++ b/Project Blue App/desktop_pet/upgrade-sync.cjs	
@@ -0,0 +1,251 @@
+"use strict";
+
+const fs = require("node:fs");
+const os = require("node:os");
+const path = require("node:path");
+const { runBoundedProcess } = require("./process-runner.cjs");
+const desktopVersion = require("./package.json").version;
+
+const SYNC_SCHEMA = "project-blue-shared-upgrade-sync-v1";
+
+function splitLines(value) {
+  return String(value || "")
+    .replace(/\r\n/g, "\n")
+    .split("\n")
+    .map(line => line.trimEnd())
+    .filter(Boolean);
+}
+
+function parseAheadBehind(indicator) {
+  const result = { ahead: 0, behind: 0 };
+  for (const part of String(indicator || "").split(",")) {
+    const ahead = part.match(/ahead\s+(\d+)/i);
+    const behind = part.match(/behind\s+(\d+)/i);
+    if (ahead) result.ahead = Number(ahead[1]);
+    if (behind) result.behind = Number(behind[1]);
+  }
+  return result;
+}
+
+function parseBranchStatus(output) {
+  const lines = splitLines(output);
+  const status = {
+    branch: "unknown",
+    upstream: "",
+    ahead: 0,
+    behind: 0,
+    clean: true,
+    changes: []
+  };
+
+  if (lines[0]?.startsWith("## ")) {
+    const header = lines.shift().slice(3).trim();
+    const match = header.match(/^(.+?)(?:\.\.\.([^\s]+))?(?:\s+\[(.+)\])?$/);
+    if (match) {
+      status.branch = match[1].trim();
+      status.upstream = (match[2] || "").trim();
+      Object.assign(status, parseAheadBehind(match[3] || ""));
+    } else if (header) {
+      status.branch = header;
+    }
+  }
+
+  status.changes = lines.map(line => ({
+    code: line.slice(0, 2),
+    path: line.slice(3).trim()
+  })).filter(change => change.path);
+  status.clean = status.changes.length === 0;
+  return status;
+}
+
+function classifySyncState(status) {
+  if (!status || typeof status !== "object") return "unknown";
+  if (!status.upstream) return "no-upstream";
+  if (!status.clean) return "local-uncommitted-changes";
+  if (status.ahead > 0 && status.behind > 0) return "diverged";
+  if (status.behind > 0) return "behind-roommate";
+  if (status.ahead > 0) return "ahead-of-roommate";
+  return "synced";
+}
+
+function syncAdvice(state, status = {}) {
+  switch (state) {
+    case "synced":
+      return "Both PCs should see the same committed Blue version after they pull.";
+    case "behind-roommate":
+      return `Your roommate has ${status.behind} committed upgrade(s). Back up, then pull.`;
+    case "ahead-of-roommate":
+      return `You have ${status.ahead} committed upgrade(s). Push them so your roommate can pull.`;
+    case "diverged":
+      return "Both PCs have unique commits. Stop and merge with a human review.";
+    case "local-uncommitted-changes":
+      return "This PC has uncommitted local edits. Commit, stash, or review them before syncing.";
+    case "no-upstream":
+      return "This branch has no upstream remote. Connect it to the shared GitHub repository first.";
+    default:
+      return "Sync state is unknown. Check Git and network access.";
+  }
+}
+
+function normalizeRepoRoot(repoRoot) {
+  const resolved = path.resolve(String(repoRoot || ""));
+  if (!path.isAbsolute(resolved)) {
+    throw new Error("Shared sync requires an absolute repository path.");
+  }
+  return resolved;
+}
+
+function safeDirectoryValue(repoRoot) {
+  return repoRoot.replace(/\\/g, "/");
+}
+
+async function runGit(repoRoot, args, limits = {}) {
+  const repository = normalizeRepoRoot(repoRoot);
+  return runBoundedProcess(
+    "git",
+    ["-c", `safe.directory=${safeDirectoryValue(repository)}`, "-C", repository, ...args],
+    { cwd: repository, windowsHide: true, shell: false },
+    {
+      timeoutMs: limits.timeoutMs || 45000,
+      maxOutputBytes: limits.maxOutputBytes || 1048576
+    }
+  );
+}
+
+async function tryGit(repoRoot, args, fallback = "") {
+  try {
+    return await runGit(repoRoot, args, { timeoutMs: 20000, maxOutputBytes: 262144 });
+  } catch {
+    return fallback;
+  }
+}
+
+function shortCommit(value) {
+  const text = String(value || "").trim();
+  return text.length > 12 ? text.slice(0, 12) : text;
+}
+
+async function readSharedSyncStatus(repoRoot, appRoot) {
+  const repository = normalizeRepoRoot(repoRoot);
+  const statusOutput = await runGit(repository, ["status", "--short", "--branch"]);
+  const branchStatus = parseBranchStatus(statusOutput);
+  const state = classifySyncState(branchStatus);
+  const [head, upstreamHead, remoteUrl, latestCommit] = await Promise.all([
+    tryGit(repository, ["rev-parse", "HEAD"], "unknown"),
+    branchStatus.upstream
+      ? tryGit(repository, ["rev-parse", "@{u}"], "unknown")
+      : Promise.resolve(""),
+    tryGit(repository, ["remote", "get-url", "origin"], "origin not configured"),
+    tryGit(repository, ["log", "-1", "--pretty=%h %cd %s", "--date=iso"], "unknown")
+  ]);
+  return {
+    schema: SYNC_SCHEMA,
+    checkedAt: new Date().toISOString(),
+    host: os.hostname(),
+    desktopVersion,
+    repositoryRoot: repository,
+    appRoot: path.resolve(String(appRoot || repository)),
+    sharedSource: "GitHub remote named origin",
+    sameWifiMode: "Use the shared repository as the meeting place; no direct LAN file writes.",
+    state,
+    summary: syncAdvice(state, branchStatus),
+    status: {
+      ...branchStatus,
+      head: head.trim(),
+      headShort: shortCommit(head),
+      upstreamHead: upstreamHead.trim(),
+      upstreamHeadShort: shortCommit(upstreamHead),
+      remoteUrl: remoteUrl.trim(),
+      latestCommit: latestCommit.trim()
+    },
+    safeRules: [
+      "Blue checks remote commits before changing files.",
+      "Blue creates a local data backup before pulling upgrades.",
+      "Blue refuses to pull over uncommitted edits.",
+      "Blue refuses automatic merges when both PCs changed different commits.",
+      "Blue only pushes commits that already exist locally; it does not invent commits silently."
+    ]
+  };
+}
+
+async function fetchSharedSyncStatus(repoRoot, appRoot) {
+  const repository = normalizeRepoRoot(repoRoot);
+  await runGit(repository, ["fetch", "--prune", "origin"], {
+    timeoutMs: 120000,
+    maxOutputBytes: 1048576
+  });
+  return readSharedSyncStatus(repository, appRoot);
+}
+
+function timestampForPath(date = new Date()) {
+  return date.toISOString()
+    .replace(/[-:]/g, "")
+    .replace(/\..+$/, "")
+    .replace("T", "-");
+}
+
+function safeHostName() {
+  return os.hostname().replace(/[^a-z0-9_.-]+/gi, "_").slice(0, 60) || "pc";
+}
+
+function copyDirectoryIfPresent(source, target) {
+  if (!fs.existsSync(source)) return false;
+  fs.mkdirSync(path.dirname(target), { recursive: true });
+  fs.cpSync(source, target, {
+    recursive: true,
+    force: false,
+    errorOnExist: false
+  });
+  return true;
+}
+
+async function createSharedSyncBackup(appRoot, repoRoot, reason = "manual shared sync backup") {
+  const appDirectory = path.resolve(String(appRoot || ""));
+  const repository = normalizeRepoRoot(repoRoot);
+  const backupRoot = path.join(
+    appDirectory,
+    "release_backups",
+    `sync-${timestampForPath()}-${safeHostName()}`
+  );
+  fs.mkdirSync(backupRoot, { recursive: true });
+  const status = await readSharedSyncStatus(repository, appDirectory).catch(error => ({
+    error: error.message
+  }));
+  const copiedBlueData = copyDirectoryIfPresent(
+    path.join(appDirectory, ".blue"),
+    path.join(backupRoot, "blue-data")
+  );
+  const manifest = {
+    schema: "project-blue-shared-sync-backup-v1",
+    createdAt: new Date().toISOString(),
+    host: os.hostname(),
+    reason,
+    appRoot: appDirectory,
+    repositoryRoot: repository,
+    copiedBlueData,
+    git: status
+  };
+  const manifestPath = path.join(backupRoot, "SYNC_BACKUP_MANIFEST.json");
+  fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`, "utf8");
+  return {
+    backupRoot,
+    manifestPath,
+    copiedBlueData,
+    message: copiedBlueData
+      ? "Backed up Blue's local memory/config data before shared sync."
+      : "Created a sync backup manifest. No .blue data folder was present to copy."
+  };
+}
+
+async function pullSharedUpgrade(repoRoot, appRoot) {
+  const before = await fetchSharedSyncStatus(repoRoot, appRoot);
+  if (!before.status.clean) {
+    throw new Error("Blue will not pull while this PC has uncommitted local edits.");
+  }
+  if (before.state === "diverged") {
+    throw new Error("Both PCs have unique commits. Ask a human to merge before pulling.");
+  }
+  const backup = await createSharedSyncBackup(appRoot, repoRoot, "pre-pull shared upgrade backup");
+  if (before.status.behind === 0) {
+    return {
+      state: "already-current",
+      before,
+      after: before,
+      backup,
+      output: "No roommate upgrades were waiting on origin.",
+      restartRequired: false
+    };
+  }
+  const branch = before.status.branch === "unknown" ? "main" : before.status.branch;
+  const output = await runGit(repoRoot, ["pull", "--ff-only", "origin", branch], {
+    timeoutMs: 120000,
+    maxOutputBytes: 2097152
+  });
+  const after = await readSharedSyncStatus(repoRoot, appRoot);
+  return {
+    state: "pulled",
+    before,
+    after,
+    backup,
+    output,
+    restartRequired: true
+  };
+}
+
+async function publishSharedUpgrade(repoRoot, appRoot) {
+  const before = await fetchSharedSyncStatus(repoRoot, appRoot);
+  if (!before.status.clean) {
+    throw new Error("Blue will not push while this PC has uncommitted local edits.");
+  }
+  if (before.status.behind > 0) {
+    throw new Error("Your roommate has commits you do not have yet. Pull and review first.");
+  }
+  if (before.status.ahead === 0) {
+    return {
+      state: "nothing-to-publish",
+      before,
+      after: before,
+      output: "No local commits are waiting to publish.",
+      restartRequired: false
+    };
+  }
+  const branch = before.status.branch === "unknown" ? "main" : before.status.branch;
+  const output = await runGit(repoRoot, ["push", "origin", branch], {
+    timeoutMs: 120000,
+    maxOutputBytes: 2097152
+  });
+  const after = await fetchSharedSyncStatus(repoRoot, appRoot);
+  return {
+    state: "published",
+    before,
+    after,
+    output,
+    restartRequired: false
+  };
+}
+
+module.exports = {
+  SYNC_SCHEMA,
+  parseBranchStatus,
+  classifySyncState,
+  syncAdvice,
+  readSharedSyncStatus,
+  fetchSharedSyncStatus,
+  createSharedSyncBackup,
+  pullSharedUpgrade,
+  publishSharedUpgrade
+};
diff --git a/Project Blue App/desktop_pet/test/upgrade-sync.test.cjs b/Project Blue App/desktop_pet/test/upgrade-sync.test.cjs
new file mode 100644
index 0000000..f8ecbf3
--- /dev/null
+++ b/Project Blue App/desktop_pet/test/upgrade-sync.test.cjs	
@@ -0,0 +1,48 @@
+"use strict";
+
+const assert = require("node:assert/strict");
+const test = require("node:test");
+const {
+  parseBranchStatus,
+  classifySyncState,
+  syncAdvice
+} = require("../upgrade-sync.cjs");
+
+test("shared sync parses clean branch status", () => {
+  const parsed = parseBranchStatus("## main...origin/main\n");
+  assert.equal(parsed.branch, "main");
+  assert.equal(parsed.upstream, "origin/main");
+  assert.equal(parsed.ahead, 0);
+  assert.equal(parsed.behind, 0);
+  assert.equal(parsed.clean, true);
+  assert.equal(classifySyncState(parsed), "synced");
+});
+
+test("shared sync detects roommate commits waiting remotely", () => {
+  const parsed = parseBranchStatus("## main...origin/main [behind 2]\n");
+  assert.equal(parsed.behind, 2);
+  assert.equal(classifySyncState(parsed), "behind-roommate");
+  assert.match(syncAdvice(classifySyncState(parsed), parsed), /pull/i);
+});
+
+test("shared sync detects local commits ready to publish", () => {
+  const parsed = parseBranchStatus("## main...origin/main [ahead 1]\n");
+  assert.equal(parsed.ahead, 1);
+  assert.equal(classifySyncState(parsed), "ahead-of-roommate");
+  assert.match(syncAdvice(classifySyncState(parsed), parsed), /push/i);
+});
+
+test("shared sync refuses automatic divergent upgrades", () => {
+  const parsed = parseBranchStatus("## main...origin/main [ahead 1, behind 3]\n");
+  assert.equal(parsed.ahead, 1);
+  assert.equal(parsed.behind, 3);
+  assert.equal(classifySyncState(parsed), "diverged");
+  assert.match(syncAdvice(classifySyncState(parsed), parsed), /merge/i);
+});
+
+test("shared sync protects uncommitted edits", () => {
+  const parsed = parseBranchStatus([
+    "## main...origin/main",
+    " M Project Blue App/desktop_pet/main.cjs",
+    "?? notes.md"
+  ].join("\n"));
+  assert.equal(parsed.clean, false);
+  assert.equal(parsed.changes.length, 2);
+  assert.equal(classifySyncState(parsed), "local-uncommitted-changes");
+});
